meta {
  name: List users
  type: http
  seq: 1
}

get {
  url: https://api.example.com/users
  body: none
  auth: oauth2
}

auth:oauth2 {
  grant_type: client_credentials
  access_token_url: https://auth.example.com/oauth/token
  client_id: my-app
  client_secret: {{oauthSecret}}
  scope: read:users
  audience: https://api.example.com
}
